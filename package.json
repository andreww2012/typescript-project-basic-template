{
  "name": "typescript-project-basic-template",
  "version": "0.0.0",
  "private": true,
  "license": "MIT",
  "author": "andreww2012",
  "type": "module",
  "main": "index.js",
  "scripts": {
    "u": "ncu",
    "u:m": "ncu -t minor",
    "u:pm": "ncu --dep packageManager",
    "deps:audit": "pnpm audit --audit-level high",
    "deps:dedupe-check": "pnpm dedupe --check",
    "spellcheck": "cspell --no-progress --no-summary .",
    "format:check": "prettier --check . --log-level warn",
    "format:fix": "prettier --write . --log-level warn",
    "eslint:inspect": "eslint-config-inspector --open false",
    "lint:eslint": "eslint --cache --concurrency auto",
    "lint:types": "tsc --noEmit",
    "lint": "nr format:check && nr lint:types && nr lint:eslint",
    "lint:fix": "nr format:fix && nr lint:eslint:fix",
    "knip": "knip --no-progress",
    "test": "nr deps:audit && nr knip && nr spellcheck && nr lint"
  },
  "dependencies": {
    "es-toolkit": "1.46.0",
    "type-fest": "5.6.0"
  },
  "devDependencies": {
    "@antfu/ni": "30.1.0",
    "@commitlint/cli": "20.5.0",
    "@commitlint/config-conventional": "20.5.0",
    "@commitlint/types": "20.5.0",
    "@eslint/config-inspector": "2.0.0",
    "@types/node": "22.19.17",
    "cross-env": "10.1.0",
    "cspell": "10.0.0",
    "eslint": "10.2.1",
    "eslint-config-un": "1.0.0-beta.8",
    "knip": "6.6.1",
    "lefthook": "2.1.6",
    "npm-check-updates": "21.0.3",
    "prettier": "3.8.3",
    "semver": "7.7.4",
    "tsx": "4.21.0",
    "typescript": "6.0.3"
  },
  "packageManager": "pnpm@10.33.1",
  "engines": {
    "node": "^22.18.0 || >=24"
  }
}